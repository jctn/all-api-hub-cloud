{
  "name": "all-api-hub-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/cli",
    "packages/desktop",
    "packages/server"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "dev:desktop": "npm run dev --workspace @all-api-hub/desktop",
    "start:desktop": "npm run start --workspace @all-api-hub/desktop",
    "dev:server": "npm run dev --workspace @all-api-hub/server",
    "start:server": "npm run start --workspace @all-api-hub/server",
    "checkin": "npm run dev --workspace @all-api-hub/cli --",
    "clean:desktop": "npm run clean --workspace @all-api-hub/desktop",
    "release:desktop": "npm run clean:desktop && npm run build && npm run dist:win --workspace @all-api-hub/desktop"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.1.14",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.1.0",
    "electron": "^37.2.5",
    "electron-builder": "^26.0.12",
    "pg-mem": "^3.0.5",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vite": "^7.1.9",
    "vitest": "^4.0.7"
  }
}
