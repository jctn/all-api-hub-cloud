{
  "name": "@all-api-hub/desktop",
  "version": "0.1.0",
  "type": "module",
  "description": "Simplified All API Hub desktop app with import, account management, and New API / AnyRouter / WONG check-in.",
  "author": "OpenAI Codex",
  "main": "./dist-electron/main.js",
  "scripts": {
    "clean": "node ./scripts/clean-artifacts.mjs",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsup --config tsup.config.ts",
    "dev": "vite",
    "start": "electron dist-electron/main.js",
    "dist:win": "electron-builder --win nsis"
  },
  "dependencies": {
    "@all-api-hub/core": "0.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "build": {
    "appId": "com.allapihub.desktop",
    "productName": "All API Hub Desktop",
    "electronVersion": "37.10.3",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist-renderer/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "win": {
      "target": ["nsis"]
    }
  }
}
