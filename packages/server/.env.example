# Zeabur usually injects PORT automatically.
# PORT=3000

# Prefer DATABASE_URL. The server will fall back to POSTGRES_CONNECTION_STRING.
DATABASE_URL=postgres://user:password@host:5432/all_api_hub
# POSTGRES_CONNECTION_STRING=

ALL_API_HUB_DATA_DIR=/data/all-api-hub
CHROMIUM_PATH=/usr/bin/chromium
LINUXDO_BASE_URL=https://linux.do
TZ=Asia/Shanghai

TG_BOT_TOKEN=123456:replace_me
# Use a random 48-64 char string.
TG_WEBHOOK_SECRET=replace-with-random-secret
TG_ADMIN_CHAT_ID=123456789
# Use a random 48-64 char string for Authorization: Bearer <token>.
INTERNAL_ADMIN_TOKEN=replace-with-random-token

GITHUB_USERNAME=replace_me
GITHUB_PASSWORD=replace_me
# GitHub TOTP setup key / Base32 secret, not the current 6-digit code.
GITHUB_TOTP_SECRET=JBSWY3DPEHPK3PXP

# Optional: auto-solve Cloudflare / Turnstile challenges during auth refresh.
# CLOUDFLYER_SERVICE_URL=http://cloudflyer.zeabur.internal:3000
# CLOUDFLYER_CLIENT_KEY=replace_me

# Default import source for this repository; change these 4 values if your backup lives elsewhere.
IMPORT_REPO_OWNER=jctn
IMPORT_REPO_NAME=all-api-hub-cloud
IMPORT_REPO_PATH=all-api-hub-backup-2026-03-19.json
IMPORT_REPO_REF=main
IMPORT_GITHUB_PAT=github_pat_replace_me

# Recommended: store site-login-profiles.json in your private data repo and point to it here.
# When SITE_LOGIN_PROFILES_REPO_PATH is set, the server will load that file from GitHub at startup.
# SITE_LOGIN_PROFILES_REPO_OWNER=
# SITE_LOGIN_PROFILES_REPO_NAME=
SITE_LOGIN_PROFILES_REPO_PATH=site-login-profiles.json
# SITE_LOGIN_PROFILES_REPO_REF=
# SITE_LOGIN_PROFILES_GITHUB_PAT=

# SITE_LOGIN_PROFILES_JSON may be an empty object on first deploy.
# SITE_LOGIN_PROFILES_JSON remains available as an inline fallback when you do not use SITE_LOGIN_PROFILES_REPO_PATH.
# See examples/site-login-profiles.example.json for a real profile shape.
# tmp-import.json in the repo root is only a smoke-test sample and should not be used as the formal import source.
SITE_LOGIN_PROFILES_JSON={}
