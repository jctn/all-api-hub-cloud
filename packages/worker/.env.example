# Required: Zeabur server base URL, without a trailing slash is recommended.
ALL_API_HUB_SERVER_URL=https://your-zeabur-domain.example.com

# Must match the LOCAL_WORKER_TOKEN configured on the server.
LOCAL_WORKER_TOKEN=replace-with-random-worker-token

# Optional: defaults to local-browser-1.
LOCAL_WORKER_ID=local-browser-1

# Required: private data repository clone or local seed/config directory.
ALL_API_HUB_PRIVATE_DATA_DIR=E:/all-api-hub-private-data

# Optional: defaults to %LOCALAPPDATA%/all-api-hub-worker on Windows.
# ALL_API_HUB_DATA_DIR=E:/all-api-hub-local-runtime

# Optional: point to a local Chromium/Chrome executable if Playwright should not use its default.
# CHROMIUM_PATH=C:/Program Files/Google/Chrome/Application/chrome.exe

GITHUB_USERNAME=replace_me
GITHUB_PASSWORD=replace_me
GITHUB_TOTP_SECRET=JBSWY3DPEHPK3PXP
LINUXDO_BASE_URL=https://linux.do

# Optional: polling and heartbeat tuning.
# LOCAL_WORKER_POLL_INTERVAL_MS=15000
# LOCAL_WORKER_HEARTBEAT_INTERVAL_MS=15000
# LOCAL_WORKER_CLAIM_TIMEOUT_MS=45000
# LOCAL_WORKER_HEARTBEAT_TIMEOUT_MS=90000

# Optional: enable a locally running FlareSolverr for local-browser worker flows.
# LOCAL_FLARESOLVERR_ENABLED=true
# LOCAL_FLARESOLVERR_URL=http://127.0.0.1:8191
# LOCAL_FLARESOLVERR_TIMEOUT_MS=90000

# Optional: only for local RunAnytime debugging. When enabled, the worker will
# open https://runanytime.hxi.me/ and pause instead of continuing the automatic
# check-in flow.
# LOCAL_WORKER_DEBUG_RUNANYTIME_ROOT_ONLY=1
